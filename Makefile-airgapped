# Superset MCP Service Makefile for Air-Gapped OpenShift Deployment

.PHONY: help prepare build deploy clean logs health test

# Default target
help:
	@echo "Superset MCP Service - Air-Gapped OpenShift Deployment"
	@echo ""
	@echo "Preparation commands (run on connected system):"
	@echo "  prepare-chrome    - Download Chrome and ChromeDriver"
	@echo "  prepare-python    - Download Python dependencies"
	@echo "  prepare-all       - Download all dependencies"
	@echo ""
	@echo "Deployment commands (run in air-gapped environment):"
	@echo "  build             - Build the Docker image in OpenShift"
	@echo "  deploy            - Deploy the service to OpenShift"
	@echo "  clean             - Remove all OpenShift resources"
	@echo "  logs              - Show service logs"
	@echo "  health            - Check service health"
	@echo "  test              - Run basic connectivity tests"
	@echo "  help              - Show this help message"

# Preparation commands (run on internet-connected system)
prepare-chrome:
	@echo "Downloading Chrome and ChromeDriver..."
	@mkdir -p chrome
	@wget -O chrome/google-chrome-stable_current_x86_64.rpm \
		https://dl.google.com/linux/direct/google-chrome-stable_current_x86_64.rpm
	@CHROME_VERSION=$$(wget -qO- https://dl.google.com/linux/direct/google-chrome-stable_current_x86_64.rpm 2>/dev/null | rpm -qp --queryformat '%{VERSION}' 2>/dev/null || echo "114.0.5735.90"); \
	CHROMEDRIVER_VERSION=$$(curl -sS chromedriver.storage.googleapis.com/LATEST_RELEASE_$${CHROME_VERSION}); \
		wget -O chrome/chromedriver_linux64.zip \
		"https://chromedriver.storage.googleapis.com/$${CHROMEDRIVER_VERSION}/chromedriver_linux64.zip"
	@echo "Chrome files downloaded to chrome/ directory"
	@ls -la chrome/

prepare-python:
	@echo "Downloading Python dependencies..."
	@mkdir -p python-packages
	@pip download -r requirements.txt -d python-packages/
	@echo "Python packages downloaded to python-packages/ directory"
	@ls -la python-packages/ | head -10

prepare-all: prepare-chrome prepare-python
	@echo "All dependencies prepared for air-gapped deployment"
	@echo "Copy the entire project directory to air-gapped environment"

# Deployment commands (run in air-gapped environment)
build:
	@echo "Building Superset MCP Service in air-gapped OpenShift..."
	@if [ ! -d "chrome" ]; then echo "❌ chrome/ directory not found. Run 'make prepare-chrome' first."; exit 1; fi
	@if [ ! -f "requirements.txt" ]; then echo "❌ requirements.txt not found."; exit 1; fi
	oc start-build superset-mcp --from-dir=. --follow

deploy: 
	@echo "Deploying Superset MCP Service to air-gapped OpenShift..."
	@if [ ! -d "chrome" ]; then echo "❌ chrome/ directory not found. Run 'make prepare-chrome' first."; exit 1; fi
	oc apply -f openshift-config-secret.yaml
	oc apply -f openshift-buildconfig.yaml
	oc apply -f openshift-deployment.yaml
	@echo "Waiting for deployment to be ready..."
	oc rollout status deployment/superset-mcp
	@echo "Deployment completed!"
	@echo "Route URL: https://$(oc get route superset-mcp -o jsonpath='{.spec.host}')"

deploy-with-selenium:
	@echo "Deploying Superset MCP Service with Selenium support..."
	@if [ ! -d "chrome" ]; then echo "❌ chrome/ directory not found. Run 'make prepare-chrome' first."; exit 1; fi
	oc apply -f openshift-config-secret.yaml
	oc apply -f openshift-buildconfig.yaml
	oc apply -f openshift-deployment-with-selenium.yaml
	@echo "Waiting for deployment to be ready..."
	oc rollout status deployment/superset-mcp
	@echo "Deployment completed!"
	@echo "Route URL: https://$(oc get route superset-mcp -o jsonpath='{.spec.host}')"

# Clean up all resources
clean:
	@echo "Removing Superset MCP Service from OpenShift..."
	oc delete route,deployment,service,hpa,buildconfig,imagestream,secret -l app=superset-mcp --ignore-not-found=true
	@echo "Cleanup completed!"

# Show logs
logs:
	@echo "Showing Superset MCP Service logs..."
	oc logs -l app=superset-mcp -f

# Check health
health:
	@echo "Checking Superset MCP Service health..."
	@echo "Pods:"
	oc get pods -l app=superset-mcp
	@echo ""
	@echo "Services:"
	oc get svc -l app=superset-mcp
	@echo ""
	@echo "Routes:"
	oc get route -l app=superset-mcp
	@echo ""
	@echo "Health Check:"
	curl -f https://$(oc get route superset-mcp -o jsonpath='{.spec.host}')/health || echo "❌ Health check failed"

# Run basic tests
test:
	@echo "Running basic connectivity tests..."
	@echo "Testing health endpoint..."
	curl -f https://$(oc get route superset-mcp -o jsonpath='{.spec.host}')/health || (echo "❌ Health check failed" && exit 1)
	@echo "✅ Health check passed"
	@echo "Testing MCP endpoint..."
	curl -X POST https://$(oc get route superset-mcp -o jsonpath='{.spec.host}')/mcp \
		-H "Content-Type: application/json" \
		-d '{"jsonrpc": "2.0", "method": "tools/list", "id": 1}' || (echo "❌ MCP endpoint test failed" && exit 1)
	@echo "✅ MCP endpoint test passed"

# Validate air-gapped prerequisites
validate:
	@echo "Validating air-gapped deployment prerequisites..."
	@if [ ! -d "chrome" ]; then echo "❌ chrome/ directory missing"; exit 1; fi
	@if [ ! -f "chrome/google-chrome-stable_current_x86_64.rpm" ]; then echo "❌ Chrome RPM missing"; exit 1; fi
	@if [ ! -f "chrome/chromedriver_linux64.zip" ]; then echo "❌ ChromeDriver ZIP missing"; exit 1; fi
	@if [ ! -f "requirements.txt" ]; then echo "❌ requirements.txt missing"; exit 1; fi
	@if [ ! -d "mcp_service" ]; then echo "❌ mcp_service/ directory missing"; exit 1; fi
	@echo "✅ All prerequisites validated for air-gapped deployment"

# Scale deployment
scale:
	@if [ -z "$(REPLICAS)" ]; then echo "Usage: make scale REPLICAS=3"; exit 1; fi
	@echo "Scaling to $(REPLICAS) replicas..."
	oc scale deployment superset-mcp --replicas=$(REPLICAS)
	oc rollout status deployment/superset-mcp

# Get shell access to pod
shell:
	@echo "Getting shell access to MCP Service pod..."
	oc exec -it $$(oc get pods -l app=superset-mcp -o jsonpath='{.items[0].metadata.name}') -- /bin/bash

# Show configuration
config:
	@echo "Showing Superset MCP Service configuration..."
	@echo "Secret:"
	oc get secret superset-mcp-config -o yaml
	@echo ""
	@echo "Deployment:"
	oc get deployment superset-mcp -o yaml | grep -A 20 "env:"
