## 📁 Beispiel 9: Monitoring Configuration

```yaml
# librechat-monitoring.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: librechat-monitoring
data:
  monitoring.yml: |
    # LibreChat + Superset MCP Monitoring
    metrics:
      enabled: true
      port: 9090
      
    health_checks:
      librechat:
        url: "http://localhost:3080/health"
        interval: 30s
        timeout: 10s
        
      superset_mcp:
        url: "https://superset-mcp.apps.cluster.example.com/health"
        interval: 60s
        timeout: 15s
        
    logging:
      level: info
      mcp_requests: true
      sql_queries: true
      chart_operations: true
      
    alerts:
      - name: "MCP Service Down"
        condition: "superset_mcp_health == false"
        action: "notify_admin"
        
      - name: "High SQL Query Time"
        condition: "sql_query_duration > 30s"
        action: "log_warning"
```

## 📁 Beispiel 10: Development Setup

```bash
#!/bin/bash
# setup-librechat-dev.sh

# LibreChat Development Setup mit Superset MCP

echo "🚀 LibreChat Dev Setup mit Superset MCP..."

# 1. LibreChat klonen
git clone https://github.com/librechat/librechat.git
cd librechat

# 2. Dependencies installieren
npm install

# 3. Environment Datei erstellen
cat > .env << EOF
# Development Configuration
NODE_ENV=development
PORT=3080

# Superset MCP Development
SUPerset_MCP_ENABLED=true
SUPerset_MCP_URL=http://localhost:5008
SUPerset_MCP_USERNAME=admin
SUPerset_MCP_PASSWORD=admin
SUPerset_MCP_TIMEOUT=30000

# MCP Settings
ENABLE_MCP_TOOLS=true
MCP_SERVICE_TIMEOUT=30000
MCP_RETRY_ATTEMPTS=2

# Development Database
MONGODB_URI=mongodb://localhost:27017/librechat-dev
ME_CONFIG_MONGODB_URL=mongodb://localhost:27017/librechat-dev
EOF

# 4. MongoDB starten (falls nicht vorhanden)
docker run -d --name librechat-mongo -p 27017:27017 mongo:latest

# 5. LibreChat starten
npm run dev

echo "✅ LibreChat läuft auf http://localhost:3080"
echo "🔗 Superset MCP sollte auf http://localhost:5008 laufen"
```

## 📁 Beispiel 11: Production Deployment Script

```bash
#!/bin/bash
# deploy-librechat-production.sh

set -e

echo "🚀 LibreChat Production Deployment mit Superset MCP..."

# Environment Variablen
export SUPerset_MCP_URL="https://superset-mcp.apps.cluster.example.com"
export SUPerset_MCP_PASSWORD="${SUPERSET_PASSWORD}"
export NODE_ENV="production"

# 1. Docker Image bauen
docker build -t librechat:prod .

# 2. Security Scan
docker scan librechat:prod

# 3. Production Container starten
docker run -d \
  --name librechat-prod \
  --restart unless-stopped \
  -p 3080:3080 \
  -e SUPerset_MCP_ENABLED=true \
  -e SUPerset_MCP_URL="${SUPerset_MCP_URL}" \
  -e SUPerset_MCP_USERNAME=admin \
  -e SUPerset_MCP_PASSWORD="${SUPerset_MCP_PASSWORD}" \
  -e ENABLE_MCP_TOOLS=true \
  -e MCP_SERVICE_TIMEOUT=30000 \
  -e NODE_ENV=production \
  librechat:prod

# 4. Health Check
sleep 10
curl -f http://localhost:3080/health || exit 1

echo "✅ LibreChat Production deployed!"
echo "🌐 Available at: http://localhost:3080"
```

## 📁 Beispiel 12: Test Suite

```javascript
// tests/superset-mcp-integration.test.js
const request = require('supertest');
const app = require('../app');

describe('Superset MCP Integration', () => {
  test('should list available charts', async () => {
    const response = await request(app)
      .post('/api/mcp/call')
      .send({
        service: 'superset',
        method: 'tools/call',
        params: {
          name: 'list_charts',
          arguments: {}
        }
      });
    
    expect(response.status).toBe(200);
    expect(response.body.result).toHaveProperty('charts');
  });

  test('should execute SQL query', async () => {
    const response = await request(app)
      .post('/api/mcp/call')
      .send({
        service: 'superset',
        method: 'tools/call',
        params: {
          name: 'execute_sql',
          arguments: {
            database_id: 1,
            sql: 'SELECT COUNT(*) as total FROM users'
          }
        }
      });
    
    expect(response.status).toBe(200);
    expect(response.body.result).toHaveProperty('data');
  });

  test('should handle screenshot requests appropriately', async () => {
    const response = await request(app)
      .post('/api/mcp/call')
      .send({
        service: 'superset',
        method: 'tools/call',
        params: {
          name: 'get_chart_preview',
          arguments: {
            identifier: '123'
          }
        }
      });
    
    if (process.env.SUPerset_MCP_SCREENSHOTS === 'true') {
      expect(response.status).toBe(200);
      expect(response.body.result).toHaveProperty('preview_url');
    } else {
      expect(response.status).toBe(400);
      expect(response.body.error).toContain('not available');
    }
  });
});
```
