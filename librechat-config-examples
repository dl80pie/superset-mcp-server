## 📁 Beispiel 5: Docker Compose Integration

```yaml
# docker-compose.librechat.yml
version: '3.8'

services:
  librechat-app:
    image: ghcr.io/librechat/librechat:latest
    ports:
      - "3080:3080"
    environment:
      # Superset MCP Integration
      - SUPerset_MCP_ENABLED=true
      - SUPerset_MCP_URL=https://superset-mcp.apps.cluster.example.com
      - SUPerset_MCP_USERNAME=admin
      - SUPerset_MCP_PASSWORD=${SUPERSET_PASSWORD}
      - SUPerset_MCP_TIMEOUT=30000
      
      # LibreChat Settings
      - ENABLE_MCP_TOOLS=true
      - MCP_SERVICE_TIMEOUT=30000
      
      # Database (Beispiel)
      - MONGODB_URI=mongodb://mongo:27017/librechat
      - ME_CONFIG_MONGODB_URL=mongodb://mongo:27017/librechat
    depends_on:
      - mongo
    networks:
      - librechat-network

  mongo:
    image: mongo:latest
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db
    networks:
      - librechat-network

volumes:
  mongo_data:

networks:
  librechat-network:
    driver: bridge
```

## 📁 Beispiel 6: Kubernetes Deployment

```yaml
# librechat-k8s.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: librechat
spec:
  replicas: 2
  selector:
    matchLabels:
      app: librechat
  template:
    metadata:
      labels:
        app: librechat
    spec:
      containers:
        - name: librechat
          image: ghcr.io/librechat/librechat:latest
          ports:
            - containerPort: 3080
          env:
            - name: SUPerset_MCP_ENABLED
              value: "true"
            - name: SUPerset_MCP_URL
              value: "https://superset-mcp.apps.cluster.example.com"
            - name: SUPerset_MCP_USERNAME
              value: "admin"
            - name: SUPerset_MCP_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: librechat-secrets
                  key: superset-password
            - name: ENABLE_MCP_TOOLS
              value: "true"
            - name: MCP_SERVICE_TIMEOUT
              value: "30000"
          resources:
            requests:
              cpu: 200m
              memory: 512Mi
            limits:
              cpu: 500m
              memory: 1Gi
---
apiVersion: v1
kind: Service
metadata:
  name: librechat
spec:
  type: LoadBalancer
  ports:
    - port: 80
      targetPort: 3080
  selector:
    app: librechat
---
apiVersion: v1
kind: Secret
metadata:
  name: librechat-secrets
type: Opaque
stringData:
  superset-password: "your-secure-password"
```

